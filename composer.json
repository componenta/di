{
    "name": "componenta/di",
    "description": "PSR-11 compatible dependency injection container for PHP 8.4+ with autowiring, lazy objects, and attribute-based configuration",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "di",
        "dependency-injection",
        "container",
        "ioc",
        "psr-11",
        "autowiring",
        "lazy-objects",
        "php84",
        "attributes"
    ],
    "authors": [
        {
            "name": "Componenta",
            "email": "Componenta@example.com"
        }
    ],
    "homepage": "https://github.com/Componenta/di",
    "support": {
        "issues": "https://github.com/Componenta/di/issues",
        "source": "https://github.com/Componenta/di"
    },
    "require": {
        "php": "^8.4",
        "componenta/array": "^1.0",
        "componenta/caster": "^1.0",
        "componenta/config": "^1.0",
        "componenta/priority-list": "^1.0",
        "componenta/reflection": "^1.0",
        "componenta/validation": "^1.0",
        "componenta/var-export": "^1.0",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\DI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Componenta\\DI\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse src --level=max",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "check": [
            "@cs-check",
            "@phpstan",
            "@test"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "provide": {
        "psr/container-implementation": "2.0"
    },
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\DI\\ConfigProvider"
            ]
        }
    }
}
